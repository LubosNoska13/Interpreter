                                <expr><var name="n"/></expr>
                                </send>                                                                                                                                                     
                            </expr>
                            <arg order="1">                                                                                                                                               
                                <expr><literal class="String" value="\n"/></expr>
                            </arg>                                                                                                                                                        
                            </send>
                        </expr>                                                                                                                                                           
                        </send>                           
                    </expr>
                    </assign>                                                                                                                                                               
                </block>
                </expr>                                                                                                                                                                     
            </arg>                                      
            </send>
        </expr>
        </assign>
    </block>
    </method>
</class>
</program>
